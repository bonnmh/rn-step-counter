{
  "name": "com.stepcounter.example",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "sh scripts/with-homebrew-ruby.sh react-native run-ios --simulator \"${IOS_SIMULATOR:-iPhone 17 Pro}\"",
    "ios:device": "sh scripts/with-homebrew-ruby.sh react-native run-ios --device",
    "pods": "sh scripts/with-homebrew-ruby.sh sh -c 'bundle install && cd ios && bundle exec pod install'",
    "start": "react-native start --reset-cache",
    "clean": "react-native clean --include android,metro,watchman,yarn",
    "postclean": "sh scripts/with-homebrew-ruby.sh sh -c 'cd ios && bundle exec pod install'",
    "build:android": "react-native build-android --extra-params \"--no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a\"",
    "build:ios": "sh scripts/with-homebrew-ruby.sh react-native build-ios --mode Debug"
  },
  "dependencies": {
    "@blife/rn-step-counter": "file:..",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-circular-progress-indicator": "^4.4.2",
    "react-native-permissions": "^5.5.1",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "^0.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/runtime": "^7.29.2",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/react": "^19.2.15",
    "react-native-builder-bob": "^0.41.0",
    "react-native-monorepo-config": "^0.3.5"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
